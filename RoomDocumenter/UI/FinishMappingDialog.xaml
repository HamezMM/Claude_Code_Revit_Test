<Window x:Class="RoomDocumenter.UI.FinishMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Room Documenter — Finish Mapping"
        Height="560" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Map finish parameter strings to Revit system family types."
                   FontStyle="Italic"
                   Margin="0,0,0,8"/>

        <!-- Tab control -->
        <TabControl Grid.Row="1">

            <!-- ── Floor tab ─────────────────────────────────────────────── -->
            <TabItem Header="Floor Finishes">
                <DataGrid ItemsSource="{Binding FloorRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          Margin="4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Floor Finish String"
                                            Binding="{Binding FinishString}"
                                            Width="*"
                                            IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Mapped FloorType" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SelectedType.Name}"
                                               VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding AvailableTypes}"
                                              SelectedItem="{Binding SelectedType, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name"
                                              IsEditable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Ceiling tab ───────────────────────────────────────────── -->
            <TabItem Header="Ceiling Finishes">
                <DataGrid ItemsSource="{Binding CeilingRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          Margin="4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ceiling Finish String"
                                            Binding="{Binding FinishString}"
                                            Width="*"
                                            IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Mapped CeilingType" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SelectedType.Name}"
                                               VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding AvailableTypes}"
                                              SelectedItem="{Binding SelectedType, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name"
                                              IsEditable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Baseboard tab ─────────────────────────────────────────── -->
            <TabItem Header="Baseboard Finishes">
                <DataGrid ItemsSource="{Binding BaseboardRows}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          Margin="4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Base Finish String"
                                            Binding="{Binding FinishString}"
                                            Width="*"
                                            IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Mapped WallSweepType" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SelectedType.Name}"
                                               VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding AvailableTypes}"
                                              SelectedItem="{Binding SelectedType, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name"
                                              IsEditable="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ── Wall tab (read-only / future use) ─────────────────────── -->
            <TabItem Header="Wall Finishes">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Wall finishes are stored for scheduling but do not drive geometry in this version."
                               FontStyle="Italic" Foreground="Gray"
                               Margin="4,4,4,4" TextWrapping="Wrap"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding WallRows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Margin="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Wall Finish String"
                                                Binding="{Binding FinishString}"
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="80" Height="28" Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="80" Height="28"/>
        </StackPanel>
    </Grid>
</Window>
