<Window
    x:Class="GridBuilderAddin.UI.StructureBuilderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Structure Builder"
    Width="580"
    Height="820"
    MinWidth="480"
    MinHeight="640"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Colours ──────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="PrimaryBlue"  Color="#0070C5"/>
        <SolidColorBrush x:Key="DarkHeader"   Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorder"   Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ErrorBrush"   Color="#C0392B"/>
        <SolidColorBrush x:Key="SubCardBg"    Color="#F9F9F9"/>

        <!-- ── Card style ───────────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

        <!-- ── Sub-card (nested, slightly tinted) ───────────────────────── -->
        <Style x:Key="SubCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SubCardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="3"/>
            <Setter Property="Padding"         Value="8"/>
            <Setter Property="Margin"          Value="0,4,0,0"/>
        </Style>

        <!-- ── Section heading ──────────────────────────────────────────── -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ── Field label ──────────────────────────────────────────────── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"      Value="#333"/>
            <Setter Property="Margin"          Value="0,0,8,0"/>
        </Style>

        <!-- ── Standard text box ────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding"  Value="4,3"/>
            <Setter Property="Width"    Value="90"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <!-- ── Combo box ────────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding"  Value="4,3"/>
        </Style>

        <!-- ── Button default ───────────────────────────────────────────── -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding"  Value="18,6"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Cursor"   Value="Hand"/>
        </Style>

        <!-- ── Button primary ───────────────────────────────────────────── -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- ══ Dark header bar ════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource DarkHeader}"
                Padding="16,10">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Structure Builder"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock Text="Step 3 of 3  —  Structure Builder"
                           FontSize="10"
                           Foreground="#A0C8E8"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ══ Footer ═════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="White"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Validation message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="← Back"
                            Command="{Binding BackCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Build!"
                            Command="{Binding BuildCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Scrollable body ════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,12,16,0">

                <!-- ══ Section 1: Floor Assembly ════════════════════════════ -->
                <TextBlock Text="FLOOR ASSEMBLY" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- Floor type picker -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Floor Type" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding FloorTypes}"
                                      SelectedItem="{Binding SelectedFloorType, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"/>
                        </Grid>

                        <!-- Host level + offset -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Host Level" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LevelItems}"
                                      SelectedItem="{Binding FloorLevel, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Offset" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding FloorOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                            <TextBlock Grid.Column="4" Text=" mm" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ══ Section 2: Roof Assembly ═════════════════════════════ -->
                <TextBlock Text="ROOF ASSEMBLY" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- Roof type picker -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Roof Type" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RoofTypes}"
                                      SelectedItem="{Binding SelectedRoofType, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"/>
                        </Grid>

                        <!-- Host level + offset -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Host Level" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LevelItems}"
                                      SelectedItem="{Binding RoofLevel, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Offset" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding RoofOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                            <TextBlock Grid.Column="4" Text=" mm" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ══ Section 3: Exterior Walls ════════════════════════════ -->
                <TextBlock Text="EXTERIOR WALLS" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- Wall type picker -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Wall Type" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding WallTypes}"
                                      SelectedItem="{Binding SelectedWallType, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName"/>
                        </Grid>

                        <!-- Exterior offset from grid -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Offset from Grid"
                                       Style="{StaticResource FieldLabel}"
                                       ToolTip="Distance from perimeter grid line to exterior face of wall (≥ 0)"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding WallExteriorOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="2" Text=" mm" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                            <TextBlock Grid.Column="3" Text="(exterior face, ≥ 0)"
                                       FontSize="10" Foreground="#999"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <!-- Bottom level + offset -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Bottom Level" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LevelItems}"
                                      SelectedItem="{Binding WallBottomLevel, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Offset" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding WallBottomOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                            <TextBlock Grid.Column="4" Text=" mm" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>

                        <!-- Top level + offset -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Top Level" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LevelItems}"
                                      SelectedItem="{Binding WallTopLevel, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Offset" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding WallTopOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                            <TextBlock Grid.Column="4" Text=" mm" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ══ Section 4: Structural Columns ════════════════════════ -->
                <TextBlock Text="STRUCTURAL COLUMNS" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- Shared column level constraints -->
                        <TextBlock Text="Level Constraints (shared for all column types)"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Base Level" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LevelItems}"
                                      SelectedItem="{Binding ColumnBottomLevel, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Offset" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding ColumnBottomOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                            <TextBlock Grid.Column="4" Text=" mm" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Top Level" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LevelItems}"
                                      SelectedItem="{Binding ColumnTopLevel, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2" Text="Offset" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding ColumnTopOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80"/>
                            <TextBlock Grid.Column="4" Text=" mm" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="3,0,0,0"/>
                        </Grid>

                        <!-- ── Perimeter columns sub-card ─────────────────── -->
                        <Border Style="{StaticResource SubCard}">
                            <StackPanel>
                                <CheckBox Content="Perimeter Columns  (at each perimeter grid intersection)"
                                          IsChecked="{Binding HasPerimeterColumns, Mode=TwoWay}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,6"/>

                                <StackPanel Visibility="{Binding HasPerimeterColumns, Converter={StaticResource BoolToVis}}">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Column Type" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ColumnTypes}"
                                                  SelectedItem="{Binding PerimeterColumnType, Mode=TwoWay}"
                                                  DisplayMemberPath="DisplayName"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Interior Offset"
                                                   Style="{StaticResource FieldLabel}"
                                                   ToolTip="Distance column centerline is offset inward from the perimeter grid line (≥ 0)"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding PerimeterOffsetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Column="2" Text=" mm" FontSize="11" Foreground="#666"
                                                   VerticalAlignment="Center" Margin="3,0,0,0"/>
                                        <TextBlock Grid.Column="3" Text="(from grid line, ≥ 0)"
                                                   FontSize="10" Foreground="#999"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Midpoint perimeter columns sub-card ────────── -->
                        <Border Style="{StaticResource SubCard}">
                            <StackPanel>
                                <CheckBox Content="Midpoint Perimeter Columns  (halfway between grid intersections on perimeter)"
                                          IsChecked="{Binding HasMidpointColumns, Mode=TwoWay}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,6"/>

                                <StackPanel Visibility="{Binding HasMidpointColumns, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Column Type" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ColumnTypes}"
                                                  SelectedItem="{Binding MidpointColumnType, Mode=TwoWay}"
                                                  DisplayMemberPath="DisplayName"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Interior columns sub-card ──────────────────── -->
                        <Border Style="{StaticResource SubCard}">
                            <StackPanel>
                                <CheckBox Content="Interior Field Columns  (at all non-perimeter grid intersections)"
                                          IsChecked="{Binding HasInteriorColumns, Mode=TwoWay}"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,6"/>

                                <StackPanel Visibility="{Binding HasInteriorColumns, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Column Type" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding ColumnTypes}"
                                                  SelectedItem="{Binding InteriorColumnType, Mode=TwoWay}"
                                                  DisplayMemberPath="DisplayName"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <Rectangle Height="8"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
