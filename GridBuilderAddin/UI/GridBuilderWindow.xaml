<Window
    x:Class="GridBuilderAddin.UI.GridBuilderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Grid Builder"
    Width="560"
    MinWidth="480"
    SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    Background="#F5F5F5">

    <Window.Resources>

        <!-- ── Colours ──────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="PrimaryBlue"      Color="#0070C5"/>
        <SolidColorBrush x:Key="DarkHeader"       Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorder"       Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ErrorBrush"       Color="#C0392B"/>
        <SolidColorBrush x:Key="GridLineXBrush"   Color="#0070C5"/>
        <SolidColorBrush x:Key="GridLineYBrush"   Color="#E07000"/>

        <!-- ── Card border style ────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="White"/>
            <Setter Property="BorderBrush"      Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Padding"          Value="8"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>

        <!-- ── Section heading ──────────────────────────────────────────── -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Foreground"   Value="#555555"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

        <!-- ── Label next to a field ────────────────────────────────────── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"           Value="0,0,8,0"/>
            <Setter Property="Width"            Value="220"/>
        </Style>

        <!-- ── Standard text box ────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="4,3"/>
            <Setter Property="Width"        Value="90"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <!-- ── Text box with red border on invalid ──────────────────────── -->
        <Style x:Key="ValidatedTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsValid, RelativeSource={RelativeSource Self}}" Value="False">
                    <!-- IsValid on TextBox is always true; row-level validation handled via DataTrigger on SpacingIntervalRow -->
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Text box for spacing rows — red border when row is invalid ─ -->
        <Style x:Key="SpacingTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsValid}" Value="False">
                    <Setter Property="BorderBrush"     Value="{StaticResource ErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Button: default ──────────────────────────────────────────── -->
        <Style TargetType="Button">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="18,6"/>
            <Setter Property="MinWidth"   Value="100"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- ── Button: primary (Revit accent blue) ──────────────────────── -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"   Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#005A9E"/>
        </Style>

        <!-- ── Spacing interval row template (shared by X and Y lists) ──── -->
        <DataTemplate x:Key="SpacingRowTemplate">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Interval label -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Label}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="#444"/>

                <!-- Spacing override text box -->
                <TextBox Grid.Column="1"
                         Text="{Binding SpacingText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SpacingTextBox}"
                         Width="100"
                         HorizontalAlignment="Left"/>
            </Grid>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <!-- ══ Dark header bar ════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource DarkHeader}"
                Padding="16,12">
            <TextBlock Text="Grid Builder"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="White"/>
        </Border>

        <!-- ══ Footer (docked to bottom so it stays visible) ═════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="White"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Validation message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Create Grids"
                            Command="{Binding CreateGridsCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Scrollable body ════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,12,16,0">

                <!-- ── Section 1: Matrix Setup ───────────────────────── -->
                <TextBlock Text="GRID MATRIX" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- X grid count -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Number of X Grids (Numerical)  —  min 2"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Column="1"
                                       Text="{Binding XCountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Y grid count -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Number of Y Grids (Alphabetical)  —  min 2"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox   Grid.Column="1"
                                       Text="{Binding YCountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Default spacing -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Default Spacing (mm)"
                                       Style="{StaticResource FieldLabel}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Text="{Binding DefaultSpacingText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text=" mm"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#666"
                                           Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ── Section 2: X Spacing Overrides ───────────────── -->
                <TextBlock Text="X SPACING OVERRIDES  (mm per interval)" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}" MaxHeight="160">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding XSpacingRows}"
                                      ItemTemplate="{StaticResource SpacingRowTemplate}"
                                      Margin="0,2"/>
                    </ScrollViewer>
                </Border>

                <!-- ── Section 3: Y Spacing Overrides ───────────────── -->
                <TextBlock Text="Y SPACING OVERRIDES  (mm per interval)" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}" MaxHeight="160">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding YSpacingRows}"
                                      ItemTemplate="{StaticResource SpacingRowTemplate}"
                                      Margin="0,2"/>
                    </ScrollViewer>
                </Border>

                <!-- ── Section 4: Live Preview ───────────────────────── -->
                <TextBlock Text="SCHEMATIC PREVIEW" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <!-- Line layer -->
                        <ItemsControl ItemsSource="{Binding PreviewLines}"
                                      Width="340" Height="220"
                                      HorizontalAlignment="Left"
                                      IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="340" Height="220" Background="White"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                          X2="{Binding X2}" Y2="{Binding Y2}"
                                          StrokeThickness="1"
                                          IsHitTestVisible="False">
                                        <Line.Style>
                                            <Style TargetType="Line">
                                                <Setter Property="Stroke" Value="{StaticResource GridLineXBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsXGrid}" Value="False">
                                                        <Setter Property="Stroke" Value="{StaticResource GridLineYBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Line.Style>
                                    </Line>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Label layer -->
                        <ItemsControl ItemsSource="{Binding PreviewLabels}"
                                      Width="340" Height="220"
                                      HorizontalAlignment="Left"
                                      IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="340" Height="220"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="9"
                                               Foreground="#333"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Rectangle Height="8"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
