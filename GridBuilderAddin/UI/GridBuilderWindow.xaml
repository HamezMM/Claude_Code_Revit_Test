<Window
    x:Class="GridBuilderAddin.UI.GridBuilderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Grid Builder"
    Width="560"
    Height="780"
    MinWidth="480"
    MinHeight="620"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Colours ──────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="PrimaryBlue"    Color="#0070C5"/>
        <SolidColorBrush x:Key="DarkHeader"     Color="#2D2D2D"/>
        <SolidColorBrush x:Key="CardBorder"     Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ErrorBrush"     Color="#C0392B"/>
        <SolidColorBrush x:Key="GridLineXBrush" Color="#0070C5"/>
        <SolidColorBrush x:Key="GridLineYBrush" Color="#E07000"/>

        <!-- ── Card border style ────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="8"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

        <!-- ── Section heading ──────────────────────────────────────────── -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ── Standard text box ────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize"                   Value="12"/>
            <Setter Property="Padding"                    Value="4,3"/>
            <Setter Property="Width"                      Value="90"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <!-- ── Text box for spacing rows — red border when row is invalid ─ -->
        <Style x:Key="SpacingTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsValid}" Value="False">
                    <Setter Property="BorderBrush"     Value="{StaticResource ErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Button: default ──────────────────────────────────────────── -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding"  Value="18,6"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Cursor"   Value="Hand"/>
        </Style>

        <!-- ── Button: primary (Revit accent blue) ──────────────────────── -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
        </Style>

        <!--
            ── Spacing interval row template (shared by X and Y lists) ──────
            Each row shows either:
              • mm mode  — a single SpacingText TextBox
              • ft-in mode — FeetText + InchesText TextBoxes
            Visibility of each sub-panel is driven by IsMmMode / IsFtInMode on the row.
        -->
        <DataTemplate x:Key="SpacingRowTemplate">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Interval label -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Label}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="#444"/>

                <!-- Unit-sensitive input area -->
                <Grid Grid.Column="1">

                    <!-- mm input -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsMmMode, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding SpacingText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SpacingTextBox}"
                                 Width="100"
                                 HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- ft-in input -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsFtInMode, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding FeetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SpacingTextBox}"
                                 Width="52"
                                 HorizontalAlignment="Left"/>
                        <TextBlock Text=" ft"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="#666"
                                   Margin="2,0,8,0"/>
                        <TextBox Text="{Binding InchesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SpacingTextBox}"
                                 Width="60"
                                 HorizontalAlignment="Left"/>
                        <TextBlock Text=" in"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="#666"
                                   Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>

        <!-- ══ Dark header bar ════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource DarkHeader}"
                Padding="16,12">
            <TextBlock Text="Grid Builder"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="White"/>
        </Border>

        <!-- ══ Footer (docked to bottom so it stays visible on resize) ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="White"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Validation message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Create Grids"
                            Command="{Binding CreateGridsCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Scrollable body ════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,12,16,0">

                <!-- ── Section 1: Matrix Setup ───────────────────────── -->
                <TextBlock Text="GRID MATRIX" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <!-- X grid count — fix: FieldLabel no longer has Width="220",
                             so label stretches to fill the * column (left-justified). -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Number of X Grids (Numerical)  —  min 2"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding XCountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Y grid count -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Number of Y Grids (Alphabetical)  —  min 2"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding YCountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Default spacing — switches between mm and ft-in -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DefaultSpacingLabel}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <!-- mm variant -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Visibility="{Binding IsMmMode, Converter={StaticResource BoolToVis}}">
                                <TextBox Text="{Binding DefaultSpacingText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text=" mm"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#666"
                                           Margin="4,0,0,0"/>
                            </StackPanel>

                            <!-- ft-in variant -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Visibility="{Binding IsFtInMode, Converter={StaticResource BoolToVis}}">
                                <TextBox Text="{Binding DefaultFeetText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="55"/>
                                <TextBlock Text=" ft"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#666"
                                           Margin="2,0,8,0"/>
                                <TextBox Text="{Binding DefaultInchesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="60"/>
                                <TextBlock Text=" in"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#666"
                                           Margin="2,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Unit toggle -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Units:"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="#444"
                                       Margin="0,0,8,0"/>
                            <RadioButton Content="Millimetres"
                                         IsChecked="{Binding IsMmMode, Mode=TwoWay}"
                                         GroupName="UnitGroup"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,16,0"/>
                            <RadioButton Content="Feet &amp; Inches"
                                         IsChecked="{Binding IsFtInMode, Mode=TwoWay}"
                                         GroupName="UnitGroup"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ── Section 2: X Spacing Overrides ───────────────── -->
                <TextBlock Text="{Binding XSpacingHeading}" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}" MaxHeight="160">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding XSpacingRows}"
                                      ItemTemplate="{StaticResource SpacingRowTemplate}"
                                      Margin="0,2"/>
                    </ScrollViewer>
                </Border>

                <!-- ── Section 3: Y Spacing Overrides ───────────────── -->
                <TextBlock Text="{Binding YSpacingHeading}" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}" MaxHeight="160">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding YSpacingRows}"
                                      ItemTemplate="{StaticResource SpacingRowTemplate}"
                                      Margin="0,2"/>
                    </ScrollViewer>
                </Border>

                <!-- ── Section 4: Live Preview (centered via Viewbox) ── -->
                <TextBlock Text="SCHEMATIC PREVIEW" Style="{StaticResource SectionHeading}"/>
                <Border Style="{StaticResource Card}" Padding="8">
                    <!--
                        Viewbox scales the fixed 340×220 canvas to fill the card's
                        available width while keeping the aspect ratio.
                        HorizontalAlignment="Center" centres it horizontally.
                    -->
                    <Viewbox Stretch="Uniform"
                             HorizontalAlignment="Center"
                             MaxHeight="260">
                        <Grid Width="340" Height="220">

                            <!-- Line layer -->
                            <ItemsControl ItemsSource="{Binding PreviewLines}"
                                          Width="340" Height="220"
                                          IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="340" Height="220" Background="White"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                              X2="{Binding X2}" Y2="{Binding Y2}"
                                              StrokeThickness="1"
                                              IsHitTestVisible="False">
                                            <Line.Style>
                                                <Style TargetType="Line">
                                                    <Setter Property="Stroke" Value="{StaticResource GridLineXBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsXGrid}" Value="False">
                                                            <Setter Property="Stroke" Value="{StaticResource GridLineYBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Line.Style>
                                        </Line>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Label layer -->
                            <ItemsControl ItemsSource="{Binding PreviewLabels}"
                                          Width="340" Height="220"
                                          IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="340" Height="220"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}"
                                                   FontSize="9"
                                                   Foreground="#333"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>
                    </Viewbox>
                </Border>

                <Rectangle Height="8"/>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
